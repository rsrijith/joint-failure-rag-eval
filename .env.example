# Copy this file to .env and fill in your keys.
# .env is gitignored — never commit real keys.

# Required for Claude judge + perturbation generation
ANTHROPIC_API_KEY=

# Required for Llama-3.3-70B judge (Cerebras free tier)
CEREBRAS_API_KEY=

# Required for Mistral Large 2 judge
MISTRAL_API_KEY=

# HuggingFace token (optional — only needed for gated models; HHEM/MiniCheck/AlignScore are public)
HUGGINGFACE_TOKEN=
